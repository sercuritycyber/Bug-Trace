{
  "name": "bugtrace",
  "version": "2026.1.0",
  "description": "BugTrace – Web Security Toolkit",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npx vite --port 5173\" \"npx wait-on http://localhost:5173 && npx electron .\"",
    "build": "npx vite build",
    "dist:win": "npm run build && npx electron-builder --win",
    "dist:linux": "npm run build && npx electron-builder --linux",
    "dist": "npm run build && npx electron-builder --win --linux"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.bugtrace.app",
    "productName": "BugTrace",
    "copyright": "BugTrace v2026",
    "asar": true,
    "directories": { "output": "dist-electron" },
    "files": ["dist/**", "electron/**", "node_modules/**", "package.json"],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "public/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
